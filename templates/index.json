em\">\n      <summary>Do you offer a guarantee?</summary>\n      <p>Yes. Every order is protected by our 30-day money-back guarantee.</p>\n    </details>\n\n  </div>\n\n</section>\n\n<style>\n.elixara-faq{\n  background:#ffffff;\n  padding:50px 16px;\n}\n\n.faq-title{\n  text-align:center;\n  margin-bottom:32px;\n}\n\n.faq-title p{\n  color:#b88722;\n  letter-spacing:4px;\n  font-size:12px;\n  margin:0 0 12px;\n  font-weight:900;\n}\n\n.faq-title h2{\n  font-family:Georgia,serif;\n  font-size:clamp(34px,5vw,56px);\n  line-height:1.05;\n  font-weight:900;\n  color:#063b2a;\n  margin:0;\n}\n\n.faq-title h2 span{\n  color:#b88722;\n  font-style:italic;\n}\n\n.faq-container{\n  max-width:900px;\n  margin:auto;\n  display:flex;\n  flex-direction:column;\n  gap:14px;\n}\n\n.faq-item{\n  background:#f8f5ef;\n  border:1px solid rgba(6,59,42,.12);\n  border-radius:20px;\n  padding:0 20px;\n  box-shadow:0 6px 18px rgba(0,0,0,.04);\n  overflow:hidden;\n}\n\n.faq-item summary{\n  list-style:none;\n  cursor:pointer;\n  padding:22px 0;\n  font-size:16px;\n  font-weight:900;\n  color:#063b2a;\n  position:relative;\n  padding-right:34px;\n}\n\n.faq-item summary::-webkit-details-marker{\n  display:none;\n}\n\n.faq-item summary::after{\n  content:\"+\";\n  position:absolute;\n  right:0;\n  top:50%;\n  transform:translateY(-50%);\n  font-size:28px;\n  color:#b88722;\n  font-weight:500;\n}\n\n.faq-item[open] summary::after{\n  content:\"−\";\n}\n\n.faq-item p{\n  padding-bottom:22px;\n  margin:0;\n  color:#5f554c;\n  line-height:1.65;\n  font-size:15px;\n  font-weight:600;\n}\n\n@media(max-width:768px){\n  .elixara-faq{\n    padding:38px 14px;\n  }\n\n  .faq-title{\n    margin-bottom:24px;\n  }\n\n  .faq-item{\n    border-radius:17px;\n    padding:0 16px;\n  }\n\n  .faq-item summary{\n    font-size:15px;\n    padding:19px 0;\n  }\n\n  .faq-item p{\n    font-size:14px;\n  }\n}\n</style>",
