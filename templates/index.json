ntent:center;\n  align-items:center;\n  gap:8px;\n  text-align:center;\n  color:#8d7f72;\n  font-size:15px;\n  margin-bottom:26px;\n  font-weight:700;\n}\n\n.elixara-secure-line svg,\n.trust-item svg{\n  width:21px;\n  height:21px;\n  stroke:#b88722;\n  stroke-width:1.8;\n  fill:none;\n  stroke-linecap:round;\n  stroke-linejoin:round;\n  flex-shrink:0;\n}\n\n/* TRUST */\n\n.elixara-trust-grid{\n  display:grid;\n  grid-template-columns:1fr 1fr;\n  gap:18px 16px;\n}\n\n.trust-item{\n  display:flex;\n  align-items:flex-start;\n  gap:12px;\n  color:#7d7065;\n  font-size:15px;\n  line-height:1.45;\n}\n\n.trust-item strong{\n  color:#063b2a;\n  font-size:17px;\n  font-weight:850;\n}\n\n/* MOBILE */\n\n@media(max-width:768px){\n\n  .elixara-payment-wrapper{\n    padding:18px 14px 20px;\n  }\n\n  .elixara-payment-title{\n    font-size:12px;\n    margin-bottom:16px;\n  }\n\n  .elixara-payment-logos{\n    gap:8px;\n    margin-bottom:16px;\n  }\n\n  .elixara-payment-logos img{\n    height:40px;\n  }\n\n  .elixara-secure-line{\n    font-size:13px;\n    margin-bottom:22px;\n  }\n\n  .elixara-trust-grid{\n    gap:16px 12px;\n  }\n\n  .trust-item{\n    gap:10px;\n    font-size:12px;\n  }\n\n  .trust-item strong{\n    font-size:15px;\n  }\n\n  .elixara-secure-line svg,\n  .trust-item svg{\n    width:18px;\n    height:18px;\n  }\n\n}\n\n</style>"
