ss-subtitle{\n    font-size:13px;\n    margin-bottom:16px;\n    white-space:nowrap;\n    letter-spacing:.3px;\n  }\n\n  .elixara-logos-track{\n    gap:50px;\n    animation-duration:18s;\n  }\n\n  .logo-vogue{height:28px;}\n  .logo-elle{height:24px;}\n  .logo-healthline{height:36px;}\n  .logo-cosmo{height:28px;}\n\n}\n\n</style>",
