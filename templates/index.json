    "custom_liquid_CrwbQt": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<section class=\"elixara-complete-sections\">\n\n  <!-- SECTION 1 -->\n  <div class=\"elixara-block elixara-clinical-benefits\">\n\n    <div class=\"elixara-clinical-image\">\n      <img \n        src=\"https://cdn.shopify.com/s/files/1/1039/0962/2090/files/ChatGPT_Image_May_16_2026_12_55_38_AM.png?v=1778885766\"\n        alt=\"Elixara Hair Results\"\n      >\n    </div>\n\n    <div class=\"elixara-clinical-content\">\n      <p class=\"elixara-kicker\">4 clinically inspired benefits</p>\n\n      <h2>For stronger,<br>fuller-looking hair</h2>\n\n      <details open>\n        <summary>Helps reduce visible hair fall from the roots</summary>\n        <p>Targets the scalp and roots to support healthier-looking hair over time.</p>\n      </details>\n\n      <details>\n        <summary>Supports natural hair growth and density</summary>\n        <p>Helps create the ideal daily routine for thicker, fuller-looking hair.</p>\n      </details>\n\n      <details>\n        <summary>Strengthens roots and fragile hair fibers</summary>\n        <p>Designed to support stronger hair and reduce breakage caused by weakness.</p>\n      </details>\n\n      <details>\n        <summary>Nourishes the scalp without harsh chemicals</summary>\n        <p>Vegan, silicone-free and paraben-free for a clean daily hair ritual.</p>\n      </details>\n    </div>\n\n  </div>\n\n  <!-- SECTION 2 -->\n  <div class=\"elixara-block elixara-guarantee-card\">\n\n    <img \n      src=\"https://cdn.shopify.com/s/files/1/1039/0962/2090/files/Screenshot_20260516_003521_ChatGPT.jpg?v=1778884648\"\n      alt=\"Guarantee\"\n      class=\"elixara-guarantee-logo\"\n    >\n\n    <h2>Try Elixara™ with<br>complete confidence</h2>\n\n    <p>Thousands of customers trust Elixara™ for stronger, fuller-looking hair.</p>\n\n    <p>\n      That’s why your order is protected by our\n      <strong>30-day money-back guarantee.</strong>\n    </p>\n\n    <p>If you don’t love your experience, simply contact us and we’ll help you.</p>\n\n  </div>\n\n  <!-- SECTION 3 -->\n  <div class=\"elixara-block elixara-survey-card\">\n\n    <p class=\"elixara-survey-kicker\">We asked our customers</p>\n\n    <h2>Here’s what they told us.</h2>\n\n    <p class=\"elixara-survey-subtext\">\n      Data from a survey sent to 200 Elixara™ customers — May 2026.\n    </p>\n\n    <div class=\"elixara-survey-grid\">\n\n      <div class=\"survey-stat\">\n        <span>97%</span>\n        <p>said their hair fall looked visibly reduced with consistent use.</p>\n      </div>\n\n      <div class=\"survey-stat\">\n        <span>93%</span>\n        <p>said their roots felt stronger and healthier in less than 4 weeks.</p>\n      </div>\n\n      <div class=\"survey-stat\">\n        <span>95%</span>\n        <p>said their hair looked fuller without changing anything else.</p>\n      </div>\n\n    </div>\n\n  </div>\n\n  <!-- SECTION 4 -->\n  <div class=\"elixara-block elixara-faq\">\n\n    <div class=\"faq-title\">\n      <p>FAQ</p>\n      <h2>Questions about <span>Elixara™</span></h2>\n    </div>\n\n    <div class=\"faq-container\">\n\n      <details class=\"faq-item\" open>\n        <summary>When will I start seeing results?</summary>\n        <p>Many customers notice less visible hair fall within the first weeks.</p>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>How do I use Elixara™?</summary>\n        <p>Apply directly to the scalp and massage gently for 1–2 minutes.</p>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Is Elixara™ suitable for all hair types?</summary>\n        <p>Yes. Elixara™ is designed for all hair types.</p>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Does it make hair greasy?</summary>\n        <p>No. The lightweight texture absorbs easily into the scalp.</p>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Do you offer a guarantee?</summary>\n        <p>Yes. Every order is protected by our 30-day guarantee.</p>\n      </details>\n\n    </div>\n\n  </div>\n\n</section>\n\n<style>\n/* FORCE FULL WIDTH */\n.elixara-complete-sections{\n  width:100vw;\n  margin-left:calc(50% - 50vw);\n  margin-right:calc(50% - 50vw);\n  background:#ffffff;\n  padding:0 !important;\n  overflow:hidden;\n}\n\n.elixara-block{\n  width:100%;\n  max-width:100%;\n  margin:0 0 8px;\n  border-radius:0 !important;\n  box-sizing:border-box;\n}\n\n/* TITLES */\n.elixara-kicker,\n.elixara-survey-kicker,\n.faq-title p{\n  color:#b88722;\n  font-size:13px;\n  font-weight:900;\n  text-transform:uppercase;\n  letter-spacing:1.4px;\n  margin:0 0 10px;\n}\n\n.elixara-clinical-content h2,\n.elixara-guarantee-card h2,\n.elixara-survey-card h2,\n.faq-title h2{\n  font-family:Georgia,serif;\n  color:#063b2a;\n  font-size:clamp(32px,4.5vw,58px);\n  line-height:1.05;\n  margin:0 0 22px;\n  font-weight:900;\n}\n\n/* SECTION 1 */\n.elixara-clinical-benefits{\n  display:grid;\n  grid-template-columns:1fr 1fr;\n  gap:28px;\n  align-items:center;\n  padding:26px 18px;\n  background:#ffffff;\n  border-top:1px solid rgba(6,59,42,.08);\n  border-bottom:1px solid rgba(6,59,42,.08);\n}\n\n.elixara-clinical-image img{\n  width:100%;\n  aspect-ratio:1/1;\n  object-fit:cover;\n  border-radius:20px;\n  display:block;\n}\n\n.elixara-clinical-content details{\n  background:#ffffff;\n  border:1px solid rgba(6,59,42,.12);\n  border-radius:16px;\n  padding:17px 18px;\n  margin-bottom:10px;\n}\n\n.elixara-clinical-content summary{\n  cursor:pointer;\n  list-style:none;\n  color:#063b2a;\n  font-size:16px;\n  font-weight:850;\n}\n\n.elixara-clinical-content summary::-webkit-details-marker,\n.faq-item summary::-webkit-details-marker{\n  display:none;\n}\n\n.elixara-clinical-content summary::before{\n  content:\"✓\";\n  color:#b88722;\n  margin-right:10px;\n  font-weight:900;\n}\n\n.elixara-clinical-content summary::after{\n  content:\"▾\";\n  float:right;\n  color:#b88722;\n}\n\n.elixara-clinical-content p{\n  margin:12px 0 0;\n  color:#5f554c;\n  font-size:15px;\n  line-height:1.6;\n}\n\n/* SECTION 2 */\n.elixara-guarantee-card{\n  background:#ffffff;\n  text-align:center;\n  padding:36px 16px;\n  border-top:1px solid rgba(6,59,42,.08);\n  border-bottom:1px solid rgba(6,59,42,.08);\n}\n\n.elixara-guarantee-logo{\n  width:170px;\n  max-width:58%;\n  display:block;\n  margin:0 auto 24px;\n}\n\n.elixara-guarantee-card p{\n  max-width:700px;\n  margin:0 auto 16px;\n  color:#5f554c;\n  font-size:16px;\n  line-height:1.65;\n}\n\n.elixara-guarantee-card strong{\n  color:#063b2a;\n}\n\n/* SECTION 3 */\n.elixara-survey-card{\n  text-align:center;\n  background:#ffffff;\n  padding:36px 16px;\n  border-top:1px solid rgba(6,59,42,.08);\n  border-bottom:1px solid rgba(6,59,42,.08);\n}\n\n.elixara-survey-subtext{\n  max-width:620px;\n  margin:0 auto 28px;\n  color:#7a6e63;\n  font-size:15px;\n}\n\n.elixara-survey-grid{\n  display:grid;\n  grid-template-columns:repeat(3,1fr);\n  gap:12px;\n}\n\n.survey-stat{\n  border:1px solid rgba(6,59,42,.1);\n  border-radius:18px;\n  padding:24px 16px;\n  background:#ffffff;\n}\n\n.survey-stat span{\n  display:block;\n  color:#063b2a;\n  font-size:64px;\n  line-height:1;\n  font-weight:900;\n  margin-bottom:14px;\n}\n\n.survey-stat p{\n  color:#5f554c;\n  font-size:15px;\n  line-height:1.5;\n  margin:0;\n}\n\n/* FAQ */\n.elixara-faq{\n  background:#ffffff;\n  padding:36px 14px;\n}\n\n.faq-title{\n  text-align:center;\n  margin-bottom:26px;\n}\n\n.faq-title h2 span{\n  color:#b88722;\n  font-style:italic;\n}\n\n.faq-container{\n  max-width:900px;\n  margin:auto;\n  display:flex;\n  flex-direction:column;\n  gap:12px;\n}\n\n.faq-item{\n  border:1px solid rgba(6,59,42,.12);\n  border-radius:16px;\n  padding:0 16px;\n  background:#ffffff;\n}\n\n.faq-item summary{\n  cursor:pointer;\n  list-style:none;\n  color:#063b2a;\n  font-size:16px;\n  font-weight:900;\n  padding:20px 0;\n  position:relative;\n  padding-right:34px;\n}\n\n.faq-item summary::after{\n  content:\"+\";\n  position:absolute;\n  right:0;\n  top:50%;\n  transform:translateY(-50%);\n  color:#b88722;\n  font-size:28px;\n}\n\n.faq-item[open] summary::after{\n  content:\"−\";\n}\n\n.faq-item p{\n  padding-bottom:20px;\n  color:#5f554c;\n  font-size:15px;\n  line-height:1.6;\n  margin:0;\n}\n\n/* MOBILE */\n@media(max-width:768px){\n\n  .elixara-block{\n    margin-bottom:6px;\n  }\n\n  .elixara-clinical-benefits{\n    grid-template-columns:1fr;\n    gap:18px;\n    padding:14px;\n  }\n\n  .elixara-clinical-content h2,\n  .elixara-guarantee-card h2,\n  .elixara-survey-card h2,\n  .faq-title h2{\n    font-size:32px;\n  }\n\n  .elixara-clinical-content summary,\n  .faq-item summary{\n    font-size:15px;\n  }\n\n  .elixara-guarantee-card,\n  .elixara-survey-card{\n    padding:28px 14px;\n  }\n\n  .elixara-guarantee-logo{\n    width:140px;\n  }\n\n  .elixara-survey-grid{\n    grid-template-columns:1fr;\n    gap:10px;\n  }\n\n  .survey-stat{\n    padding:22px 14px;\n  }\n\n  .survey-stat span{\n    font-size:54px;\n  }\n\n  .elixara-faq{\n    padding:28px 10px;\n  }\n\n  .faq-item{\n    padding:0 14px;\n  }\n}\n</style>",
        "background": "",
        "background_gradient": "",
        "text_color": ""
      }
