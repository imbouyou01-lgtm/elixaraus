\n\n    </div>\n\n  </div>\n\n</section>\n\n<style>\n\n.elixara-press{\n  width:100vw;\n  margin-left:calc(50% - 50vw);\n  margin-right:calc(50% - 50vw);\n  margin-top:-22px;\n  padding:26px 0;\n  background:linear-gradient(180deg,#fbf4ea 0%,#f5eadb 100%);\n  overflow:hidden;\n}\n\n.elixara-press-subtitle{\n  text-align:center;\n  font-size:clamp(16px,1.4vw,23px);\n  font-weight:900;\n  color:#063b2a;\n  margin:0 0 26px;\n  letter-spacing:.7px;\n  text-transform:uppercase;\n  line-height:1.3;\n  padding:0 18px;\n}\n\n.elixara-logos-wrapper{\n  width:100%;\n  overflow:hidden;\n}\n\n.elixara-logos-track{\n  display:flex;\n  align-items:center;\n  gap:90px;\n  width:max-content;\n  animation:elixaraScroll 24s linear infinite;\n}\n\n.elixara-logos-track img{\n  width:auto;\n  object-fit:contain;\n  opacity:1;\n  flex-shrink:0;\n}\n\n/* DESKTOP */\n\n.logo-vogue{\n  height:42px;\n}\n\n.logo-elle{\n  height:38px;\n}\n\n.logo-healthline{\n  height:52px;\n}\n\n.logo-cosmo{\n  height:42px;\n}\n\n/* ANIMATION */\n\n@keyframes elixaraScroll{\n\n  from{\n    transform:translateX(0);\n  }\n\n  to{\n    transform:translateX(-50%);\n  }\n\n}\n\n/* MOBILE */\n\n@media(max-width:768px){\n\n  .elixara-press{\n    margin-top:-16px;\n    padding:20px 0;\n  }\n\n  .elixara-press-subtitle{\n    font-size:14px;\n    margin-bottom:20px;\n    letter-spacing:.4px;\n  }\n\n  .elixara-logos-track{\n    gap:50px;\n    animation-duration:18s;\n  }\n\n  .logo-vogue{\n    height:28px;\n  }\n\n  .logo-elle{\n    height:24px;\n  }\n\n  .logo-healthline{\n    height:36px;\n  }\n\n  .logo-cosmo{\n    height:28px;\n  }\n\n}\n\n</style>",
